
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // For prototyping: Allow public access. 
    // WARNING: In a production app, you MUST restrict this to authenticated users.
    match /{document=**} {
      allow read, write: if true;
    }
    
    match /students/{studentId} {
      allow read, write: if true;
    }
    
    match /subjectMappings/{mappingId} {
      allow read, write: if true;
    }
    
    match /marksMappings/{mappingId} {
      allow read, write: if true;
    }
    
    match /configs/{configId} {
      allow read, write: if true;
    }

    match /patrakA/{entryId} {
      allow read, write: if true;
    }
  }
}
