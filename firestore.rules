rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to all collections for authenticated users
    // In a production app, you would restrict this further based on user roles or IDs
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Explicit rules for entities defined in backend.json
    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }
    
    match /subjectMappings/{mappingId} {
      allow read, write: if request.auth != null;
    }
    
    match /marksMappings/{mappingId} {
      allow read, write: if request.auth != null;
    }
    
    match /configs/{configId} {
      allow read, write: if request.auth != null;
    }
  }
}